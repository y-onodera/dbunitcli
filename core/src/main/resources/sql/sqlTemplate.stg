DropEmpty ::= ["": [], default: key]
value(row ,column) ::=<<$if (!DropEmpty.(row.(column.columnName)))$null$elseif (column.dataType.number)$$row.(column.columnName)$$else$$row.(column.columnName); format="escapeSql"$$endif$>>
insert() ::= <<
$rows:{row |insert into $tableName$ ($columns:{column | $column.columnName$ }; separator=","$) values ($columns:{column | $value(row,column)$ }; separator=","$);
}$
>>
delete() ::= <<
$rows:{row |delete from $tableName$ where $primaryKeys:{column | $column.columnName$ = $value(row,column)$ }; separator="and "$;
}$
>>
update() ::= <<
$rows:{row |update $tableName$ set $columnsExcludeKey:{column | $column.columnName$ = $value(row,column)$ }; separator=","$ where $primaryKeys:{column | $column.columnName$ = $value(row,column)$ }; separator="and "$;
}$
>>
deleteAll() ::= <<
delete from $tableName$;
>>
commit() ::= <<$if(inputParam.commit)$commit;$endif$>>
ddlType(row) ::= <<$row.TYPE_NAME$$if(row.COLUMN_SIZE)$($row.COLUMN_SIZE$$if(row.DECIMAL_DIGITS)$,$row.DECIMAL_DIGITS$$endif$)$endif$>>
createTable() ::= <<
CREATE TABLE $tableName; format="upper"$ (
    $rows:{row | $row.COLUMN_NAME; format="upper"$ $ddlType(row)$$if(!row.NULLABLE)$ NOT NULL$endif$}; separator=",\n    "$
    $if(pkColumnNames)$,CONSTRAINT $if(pkConstraintName)$$pkConstraintName$$else$PK_$tableName; format="upper"$$endif$ PRIMARY KEY ($pkColumnNames:{name | $name; format="upper"$}; separator=", "$)
    $endif$
);
>>
commentOnTable() ::= <<$if(tableRemarks)$COMMENT ON TABLE $tableName; format="upper"$ IS '$tableRemarks$';
$endif$>>
commentOnColumns() ::= <<
$rows:{row | $if(row.REMARKS)$COMMENT ON COLUMN $tableName; format="upper"$.$row.COLUMN_NAME; format="upper"$ IS '$row.REMARKS$';
$endif$}$
>>
